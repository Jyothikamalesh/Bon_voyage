# ─────────────────────────────────────────────────────────────
# Bon Voyage Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# Google Cloud Project
GCP_PROJECT_ID=your-gcp-project-id

# Gemini API (Google AI Studio → https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Google Maps Platform API Key
# Enable: Maps JavaScript API, Places API (New), Maps Embed API
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Cloud Vision API uses Application Default Credentials (ADC) on Cloud Run
# For local dev, set path to your service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Server port (Cloud Run uses 8080 by default)
PORT=8080

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-firebase-project.web.app,https://your-firebase-project.firebaseapp.com,http://localhost:5000
